#!/usr/bin/env bash
#
# bin/smoke — full-surface smoke test for the textus CLI/engine.
#
# Runs every meaningful verb against a THROWAWAY copy of this repo's own
# `.textus/` store, so destructive verbs (build, tend, key delete-prefix) and
# role-switched proposal flows are exercised with zero risk to the live store.
#
# Why a copy of .textus rather than a fresh `init`: the init scaffold ships a
# different manifest (zones, schemas, declared entries) than the dogfooded
# store, so it would validate the engine generically but not THIS repo's
# config. Copying .textus tests the real manifest.
#
# What MCP cannot cover, and why this exists: the running MCP server is pinned
# to the live store and to the `agent` role, so over MCP you can only ever see
# propose-success + accept/reject-denial. Here, `--as=human` lets us also
# assert the happy-path promotion (propose(agent) -> accept(human)).
#
# Usage:  bin/smoke            # run, print pass/fail summary, exit nonzero on failure
#         KEEP_TMP=1 bin/smoke # leave the tmp store on disk for inspection
#
set -uo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

# --- throwaway store -------------------------------------------------------
TMP="$(mktemp -d "${TMPDIR:-/tmp}/textus-smoke.XXXXXX")"
cleanup() { [ "${KEEP_TMP:-}" = "1" ] || rm -rf "$TMP"; }
trap cleanup EXIT
cp -R "$REPO_ROOT/.textus" "$TMP/.textus"
rm -rf "$TMP/.textus/.run"   # drop session/audit/lock state from the copy

# Every call goes through the working tree (bundle exec exe/textus), pinned to
# the throwaway root. Role defaults to agent (the MCP default) unless --as says so.
t() { bundle exec exe/textus --root "$TMP/.textus" "$@" 2>&1; }

# --- assertion harness -----------------------------------------------------
pass=0; fail=0
if [ -t 1 ]; then G=$'\033[32m'; R=$'\033[31m'; D=$'\033[2m'; Z=$'\033[0m'; else G=; R=; D=; Z=; fi

ok() { printf '  %s✓%s %s\n' "$G" "$Z" "$1"; pass=$((pass + 1)); }
ko() { printf '  %s✗ %s%s\n' "$R" "$1" "$Z"; printf '      %sgot:%s %s\n' "$D" "$Z" "${2:-}"; fail=$((fail + 1)); }

# expect_has  DESC  NEEDLE  HAYSTACK   — pass when HAYSTACK contains NEEDLE
expect_has() { case "$3" in *"$2"*) ok "$1" ;; *) ko "$1 (missing: $2)" "$3" ;; esac; }
# expect_no   DESC  NEEDLE  HAYSTACK   — pass when HAYSTACK does NOT contain NEEDLE
expect_no()  { case "$3" in *"$2"*) ko "$1 (unexpected: $2)" "$3" ;; *) ok "$1" ;; esac; }

section() { printf '\n%s== %s ==%s\n' "$D" "$1" "$Z"; }

# --- contract + read path --------------------------------------------------
section "contract + read"
out=$(t boot);                            expect_has "boot returns contract"        '"zones"'                  "$out"
out=$(t capabilities);                    expect_has "capabilities lists put"       '"verb":"put"'             "$out"
out=$(t list);                            expect_has "list sees knowledge.project"  'knowledge.project'        "$out"
out=$(t get knowledge.project);           expect_has "get resolves project schema"  '"schema_ref":"project"'   "$out"
out=$(t where knowledge.project);         expect_has "where resolves zone"          '"zone":"knowledge"'       "$out"
out=$(t schema show knowledge.project);   expect_has "schema show has required"     '"required":true'          "$out"
out=$(t deps artifacts.orientation);      expect_has "deps maps derived sources"    'knowledge.project'        "$out"
out=$(t pulse);                           expect_has "pulse reports doctor ok"      '"ok":true'                "$out"
out=$(t doctor);                          expect_has "doctor healthy"               '"ok":true'                "$out"

# --- write round-trip (notebook, agent-owned) ------------------------------
section "write round-trip (notebook / agent)"
out=$(echo '{"body":"round-trip"}' | t put notebook.notes.rt --as=agent --stdin)
expect_has "put writes notebook entry"   '"key":"notebook.notes.rt"' "$out"
out=$(t get notebook.notes.rt);           expect_has "get reads it back"            'round-trip'               "$out"
out=$(t key delete notebook.notes.rt --as=agent)
expect_has "delete removes it"            '"deleted":true'           "$out"
out=$(t get notebook.notes.rt);           expect_has "gone after delete"            'unknown_key'              "$out"

# --- proposal flow: the protocol gate --------------------------------------
# Agent proposes into the queue; canon promotion needs the human `author` cap.
section "proposal flow (propose / accept / reject)"
P='proposals.notes.smoketest'
out=$(echo '{"_meta":{"proposal":{"target_key":"knowledge.runbooks.smoketest"},"name":"smoketest","description":"smoke runbook"},"body":"smoke body"}' \
       | t propose notes.smoketest --as=agent --stdin)
expect_has "propose (agent) lands in queue"  '"key":"proposals.notes.smoketest"' "$out"

out=$(t accept "$P" --as=agent)
expect_has "accept (agent) DENIED at guard"  'author_held'             "$out"

out=$(t reject "$P" --as=agent)
expect_has "reject (agent) DENIED at guard"  'author_held'             "$out"

out=$(t accept "$P" --as=human)
expect_no  "accept (human) not refused"      'guard_failed'            "$out"
out=$(t get knowledge.runbooks.smoketest)
expect_has "target promoted into canon"      '"key":"knowledge.runbooks.smoketest"' "$out"
out=$(t list --zone proposals)
expect_has "proposal consumed from queue"    '"entries":[]'            "$out"

# --- destructive verbs (safe on the throwaway root) ------------------------
section "destructive verbs (throwaway root)"
out=$(t build)
expect_has "build rebuilds orientation"      'artifacts.orientation'   "$out"
[ -f "$TMP/CLAUDE.md" ] && ok "build publishes CLAUDE.md into tmp" \
                        || ko "build publishes CLAUDE.md into tmp" "missing $TMP/CLAUDE.md"

out=$(t tend --dry-run);  expect_has "tend dry-run is non-destructive" '"dry_run":true' "$out"
out=$(t tend);            expect_has "tend real run stays healthy"     '"ok":true'      "$out"

echo '{"body":"a"}' | t put notebook.notes.a --as=agent --stdin >/dev/null
echo '{"body":"b"}' | t put notebook.notes.b --as=agent --stdin >/dev/null
out=$(t key delete-prefix notebook.notes --dry-run)
expect_has "delete-prefix dry-run plans"     'notebook.notes.a'        "$out"
out=$(t key delete-prefix notebook.notes --as=agent)
out=$(t list --zone notebook);  expect_has "delete-prefix cleared zone" '"entries":[]' "$out"

# --- repo safety check -----------------------------------------------------
section "repo safety"
dirty=$(cd "$REPO_ROOT" && git status --porcelain CLAUDE.md AGENTS.md .textus)
expect_has "live repo untouched by smoke run" "" "$dirty"

# --- summary ---------------------------------------------------------------
printf '\n%s—%s %d passed, %d failed%s\n' "$D" "$Z" "$pass" "$fail" \
  "$([ "${KEEP_TMP:-}" = "1" ] && printf ' (tmp kept: %s)' "$TMP")"
[ "$fail" -eq 0 ]
