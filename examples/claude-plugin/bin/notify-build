#!/usr/bin/env bash
# External-runner hook for the :build event.
#
# Textus itself NEVER invokes this script. A wrapper (cron, lefthook, CI, a
# Rakefile task) reads `textus hook list`, finds rows with
# `mode=manifest` + `exec:` set, and dispatches the exec string under the
# declared `as:` role.
#
# Usage: bin/notify-build KEY
#
# This minimal demo appends to .textus/notify.log. Replace with a Slack
# webhook (`curl -X POST ...`), Buildkite pipeline trigger (`bk pipeline …`),
# or whatever your environment needs.
set -euo pipefail

key="${1:-unknown}"
mkdir -p .textus
echo "$(date -u +%FT%TZ) [notify-build] $key" >> .textus/notify.log
