require "json"
require "open3"

namespace :textus do
  desc "Refresh every stale inbox entry"
  task :refresh do
    fresh_json, = Open3.capture2("textus", "freshness", "--zone=inbox")
    rows = JSON.parse(fresh_json)["rows"] || []
    keys = rows
           .select { |r| %w[stale never_refreshed].include?(r["status"]) }
           .map    { |r| r["key"] }
    if keys.empty?
      puts "no stale inbox entries"
      next
    end
    keys.each do |key|
      puts "refreshing #{key}"
      sh "textus", "refresh", key, "--as=script"
    end
  end

  desc "Refresh inbox + rebuild output + dispatch external :build hooks"
  task update: %i[refresh] do
    sh "textus build | jq -c '{built: (.built | length)}'"

    # Manifest-declared `events: { build: [{ exec: ... }] }` rows are
    # advertised by textus but never invoked by it. An external runner
    # (this Rakefile, in this example) reads the listing and dispatches.
    hooks_json, = Open3.capture2("textus", "hook", "list")
    JSON.parse(hooks_json)["hooks"].each do |row|
      next unless row["exec"] && row["event"] == "build"

      puts "dispatching #{row["exec"]} for #{row["key"]} (as=#{row["as"]})"
      sh row["exec"], row["key"]
    end
  end
end
