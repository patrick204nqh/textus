require "json"
require "open3"

namespace :textus do
  desc "Refresh every stale intake entry"
  task :refresh do
    stale_json, _ = Open3.capture2("textus", "stale", "--zone=intake", "--format=json")
    keys = JSON.parse(stale_json).map { |row| row["key"] }
    if keys.empty?
      puts "no stale intake entries"
      next
    end
    keys.each do |key|
      puts "refreshing #{key}"
      sh "textus", "refresh", key, "--as=script", "--format=json"
    end
  end

  desc "Refresh intake + rebuild derived"
  task update: %i[refresh] do
    sh "textus build --format=json | jq -c '{built: (.built | length)}'"
  end
end
