{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "ruby": {
      "type": "local",
      "command": [
        "bundle",
        "exec",
        "ruby-lsp"
      ],
      "enabled": true,
      "extensions": [
        ".rb",
        ".rake",
        ".gemspec",
        ".ru"
      ]
    }
  },
  "mcp": {
    "textus": {
      "type": "local",
      "command": [
        "bundle",
        "exec",
        "exe/textus",
        "mcp",
        "serve"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "textus@git+https://github.com/patrick204nqh/textus.git"
  ],
  "instructions": [
    "AGENTS.md"
  ]
}
