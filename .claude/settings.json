{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "bundle exec exe/textus boot --lean" }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          { "type": "command", "command": "bundle exec exe/textus boot --lean" }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "bundle exec exe/textus boot --lean" }
        ]
      }
    ]
  }
}
