{
  "name": "textus",
  "description": "Durable, multi-writer repo memory. Auto-orients each session with `textus boot`.",
  "version": "0.54.2",
  "homepage": "https://github.com/patrick204nqh/textus",
  "repository": "https://github.com/patrick204nqh/textus",
  "license": "MIT",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "textus boot"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "textus boot"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "textus boot"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "textus": {
      "command": "textus",
      "args": [
        "mcp",
        "serve"
      ]
    }
  }
}
